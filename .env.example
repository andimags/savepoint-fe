# Secret used by NextAuth to sign/encrypt session tokens.
# Generate one with: npx auth secret
AUTH_SECRET=helloworld

# Base URL of the frontend.
NEXTAUTH_URL=http://localhost:3000

# Backend base URL used in server-side code (server actions, auth.ts, route handlers).
API_URL=http://localhost:3001

# Backend base URL exposed to the browser.
NEXT_PUBLIC_API_URL=http://localhost:3001
